---
import { profile, siteUrl } from "../data/profile";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = `${profile.name} — ${profile.jobTitle} · Vue.js & AdonisJS`,
  description = profile.description,
  image = profile.ogImage,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? siteUrl).toString();
const ogImage = new URL(image, Astro.site ?? siteUrl).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": `${siteUrl}#person`,
      name: profile.name,
      url: siteUrl,
      image: ogImage,
      jobTitle: profile.jobTitle,
      email: `mailto:${profile.email}`,
      knowsAbout: [...profile.knowsAbout],
      sameAs: [...profile.sameAs],
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      name: `${profile.name} — Portfolio`,
      url: siteUrl,
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#031018" />
    <meta name="color-scheme" content="dark" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="icon" type="image/svg+xml" href="/portfolio/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/portfolio/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/portfolio/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/portfolio/apple-touch-icon.png" />
    <link rel="manifest" href="/portfolio/site.webmanifest" />

    {profile.sameAs.map((href) => <link rel="me" href={href} />)}

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/portfolio/assets/styles/main.css" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const logoContainer: HTMLElement | null =
          document.querySelector(".logo-container");
        const topbarWrapper: HTMLElement | null =
          document.querySelector(".topbar-wrapper");

        if (logoContainer) {
          function handleScroll() {
            const scrollTop =
              window.pageYOffset || document.documentElement.scrollTop;

            if (scrollTop > 50) {
              logoContainer?.classList.add("scrolled");
              topbarWrapper?.classList.add("scrolled");
            } else {
              logoContainer?.classList.remove("scrolled");
              topbarWrapper?.classList.remove("scrolled");
            }
          }

          handleScroll();
          window.addEventListener("scroll", handleScroll, { passive: true });
        }
      });
    </script>
  </body>
</html>

<style>
  html {
    min-height: 100vh;
    overflow-x: clip;
    /* scrollbar-gutter: stable; */
    background: linear-gradient(
      to bottom right,
      var(--color-primary-darker),
      var(--color-background)
    );
  }
  html,
  body {
    /* height: 100%; */
    max-width: 100vw;

    margin: 0;
    padding: 0;

    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-primary);
    background: linear-gradient(to bottom right, var(--color-primary-darker), var(--color-background));
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  ::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }

  ::-webkit-scrollbar-track {
    background: var(--color-background);
    border-left: 1px solid rgba(0, 166, 251, 0.1);
  }

  ::-webkit-scrollbar-thumb {
    background: linear-gradient(
      180deg,
      var(--color-primary-darker) 0%,
      var(--color-primary-dark) 100%
    );
    border-radius: 10px;
    border: 2px solid var(--color-background);
  }

  ::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(
      180deg,
      var(--color-primary-dark) 0%,
      var(--color-primary) 100%
    );
  }

  ::-webkit-scrollbar-thumb:active {
    background: var(--color-primary);
  }

  /* Scrollbar para Firefox */
  * {
    scrollbar-width: thin;
    scrollbar-color: var(--color-primary-dark) var(--color-background);
  }
</style>
