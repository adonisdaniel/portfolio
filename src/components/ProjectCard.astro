---
interface Props {
  title: string;
  description: string;
  stack: string[];
  image?: string;
  category?: string;
}

const { title, description, stack, image, category } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const imageSrc = image ? `${base}/${image}` : undefined;
---

<article class:list={["project-card", { "has-image": !!image }]}>
  {imageSrc && (
    <figure class="project-image">
      <img src={imageSrc} alt={`${title} preview`} loading="lazy" decoding="async" />
      <div class="project-image-overlay" aria-hidden="true"></div>
      {category && <span class="project-badge">{category}</span>}
    </figure>
  )}

  <div class="project-content">
    {!imageSrc && category && <span class="project-badge project-badge--inline">{category}</span>}

    <h3 class="project-title">{title}</h3>
    <p class="project-description">{description}</p>

    <div class="project-stack">
      <span class="stack-label">TECH STACK</span>
      <div class="stack-tags">
        {stack.map((tech) => (
          <span class="stack-tag">{tech}</span>
        ))}
      </div>
    </div>
  </div>
</article>

<style>
  .project-card {
    background: rgba(0, 166, 251, 0.03);
    border: 1px solid rgba(0, 166, 251, 0.12);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.4s cubic-bezier(0.2, 0.7, 0.2, 1),
      border-color 0.3s ease,
      box-shadow 0.4s ease;
    position: relative;
    isolation: isolate;
  }

  .project-card:hover {
    /* transform: translateY(-4px); */
    border-color: rgba(0, 166, 251, 0.45);
    box-shadow: 0 14px 40px rgba(0, 166, 251, 0.18),
      0 2px 8px rgba(0, 0, 0, 0.25);
  }

  .project-image {
    position: relative;
    margin: 0;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: linear-gradient(
      135deg,
      var(--color-secondary),
      var(--color-background)
    );
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }

  .project-card:hover .project-image img {
    transform: scale(1.04);
  }

  .project-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(5, 25, 35, 0.85) 0%,
      rgba(5, 25, 35, 0.35) 35%,
      rgba(5, 25, 35, 0) 60%
    );
    pointer-events: none;
  }

  .project-badge {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    background: var(--color-primary);
    color: var(--color-background);
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 0.4rem 0.7rem;
    border-radius: 4px;
    line-height: 1;
    z-index: 1;
  }

  .project-badge--inline {
    position: static;
    align-self: flex-start;
    margin-bottom: 0.25rem;
  }

  .project-content {
    padding: 1.75rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }

  .has-image .project-content {
    padding-top: 1.5rem;
  }

  .project-title {
    color: var(--text-heading);
    font-size: var(--fs-heading);
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.15;
    transition: color 0.3s ease;
  }

  .project-card:hover .project-title {
    color: var(--color-primary);
  }

  .project-description {
    color: var(--text-body);
    font-size: var(--fs-body);
    line-height: 1.7;
    margin: 0;
  }

  .project-stack {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .stack-label {
    color: var(--text-muted);
    font-size: var(--fs-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .stack-tag {
    background: transparent;
    color: var(--color-primary);
    padding: 0.35rem 0.7rem;
    border-radius: 4px;
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    border: 1px solid rgba(0, 166, 251, 0.25);
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .project-card:hover .stack-tag {
    background: rgba(0, 166, 251, 0.08);
    border-color: rgba(0, 166, 251, 0.5);
  }

  @media (width <= 768px) {
    .project-content {
      padding: 1.25rem 1.25rem 1.5rem;
      gap: 0.85rem;
    }

    .project-badge {
      left: 0.75rem;
      bottom: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-image img,
    .project-title,
    .stack-tag {
      transition: none;
    }

    .project-card:hover {
      transform: none;
    }

    .project-card:hover .project-image img {
      transform: none;
    }
  }
</style>
