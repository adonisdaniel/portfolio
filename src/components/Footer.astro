---
import { profile } from "../data/profile";
import GitHub from "./icons/GitHub.astro";
import Linkedin from "./icons/Linkedin.astro";
import Instagram from "./icons/Instagram.astro";

const [github, linkedin, instagram] = profile.sameAs;
const socials = [
  { label: "GitHub", href: github, Icon: GitHub },
  { label: "LinkedIn", href: linkedin, Icon: Linkedin },
  { label: "Instagram", href: instagram, Icon: Instagram },
];
---

<section class="footer">
  <footer class="site-footer" aria-label="Footer personal">
    <div class="footer-inner">
      <div class="footer-block">
        <h3>Out of Office</h3>
        <p>
          In my free time I enjoy training, reading about technology and working
          on personal projects.
        </p>
      </div>

      <div class="footer-block">
        <h3>Social Media</h3>
        {socials.map(({ label, href, Icon }) => (
          <p class="social-media-icons">
            <Icon />
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="social-media-icons-link">{label}</a
            >
          </p>
        ))}
      </div>

      <div class="footer-block footer-copy">
        <p>{profile.name} · {profile.jobTitle}</p>
      </div>
    </div>
  </footer>
</section>

<style>
  .site-footer {
    background: #031018;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 6.5rem 2rem;
    color: #d6e7f6;
    font-size: 0.95rem;
    height: 30dvh;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    height: 100%;
  }

  .footer-block h3 {
    margin: 0 0 0.6rem;
    color: #39a2f7;
  }

  .footer-block p {
    margin: 0;
    line-height: 1.6;
  }

  .site-footer a {
    color: #39a2f7;
    text-decoration: none;
  }

  .site-footer a:hover {
    text-decoration: underline;
  }

  .footer-copy {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 1rem;
    font-size: 0.875rem;
    opacity: 0.75;

    align-self: flex-end;
    text-align: center;
  }

  .social-media-icons {
    display: flex;
    align-items: center;
    height: 2rem;
  }

  .social-media-icons-link {
    margin-left: 0.5rem;
  }

  /* responsive */
  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 2fr 1.2fr;
      align-items: flex-start;
    }

    .footer-copy {
      grid-column: 1 / -1;
      /* text-align: right; */
    }
  }
</style>
