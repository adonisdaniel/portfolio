---
import Logo from "./Logo.astro";
---

<div class="topbar-wrapper">
  <div class="topbar-shadow">
    <div class="topbar-inner">
      <div class="topbar-progress" aria-hidden="true"></div>
      <div class="top-bar">
        <div class="top-bar-head">
          <Logo />
          <div class="button-menu-container">
            <button
              class="button-menu"
              type="button"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="primary-nav"
            >
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
              <span class="hamburger-line"></span>
            </button>
          </div>
        </div>
        <nav id="primary-nav" class="primary-nav" aria-label="Primary">
          <ul class="menu-items-container" role="list">
            <li class="menu-items">
              <a href="#projects" class="nav-link" data-section="projects">Projects</a>
            </li>
            <li class="menu-items">
              <a href="#about" class="nav-link" data-section="about">About</a>
            </li>
            <li class="menu-items">
              <a href="#contact" class="nav-link" data-section="contact">Contact</a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</div>

<style>

  .topbar-wrapper {
    position: fixed;
    top: 5px;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 20px 20px;
  }

  .topbar-shadow {
    max-width: 1200px;
    margin: 0 auto;
    border-radius: 12px;
    box-shadow:
      0 1px 2px -1px rgba(0, 0, 0, 0.3),
      0 4px 8px -2px rgba(0, 0, 0, 0.25),
      0 16px 32px -4px rgba(0, 166, 251, 0.08);
    }

  .topbar-inner {
    position: relative;
    background: rgba(3, 16, 24, 0.55);
    border-radius: 12px;
    overflow: hidden;
    backdrop-filter: blur(14px);
  }

  @supports not (backdrop-filter: blur(14px)) {
    .topbar-inner {
      -webkit-backdrop-filter: blur(14px);
    }
  }

  .topbar-progress {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 1px;
    width: var(--progress, 0%);
    background: linear-gradient(
      90deg,
      var(--color-primary) 0%,
      var(--color-primary-dark) 100%
    );
    box-shadow: 0 0 8px rgba(0, 166, 251, 0.5);
    pointer-events: none;
    transition: width 80ms linear;
    z-index: 1;
  }

  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 76px;
    padding: 0 48px;
    position: relative;
  }

  .top-bar-head {
    display: flex;
    align-items: center;
  }

  .button-menu-container {
    display: none;
    align-items: center;
  }

  .primary-nav {
    display: flex;
    align-items: center;
  }

  .menu-items-container {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .menu-items {
    list-style: none;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 14px;
    border-radius: 8px;
    color: rgba(224, 224, 224, 0.72);
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 400;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.06);
    text-decoration: none;
  }

  .nav-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .nav-link.is-active {
    color: #ffffff;
    background-color: rgba(0, 166, 251, 0.14);
  }

  .button-menu {
    background: transparent;
    border: 1px solid rgba(0, 166, 251, 0.25);
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    width: 38px;
    height: 38px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .button-menu:hover,
  .button-menu:focus-visible {
    border-color: var(--color-primary);
    background-color: rgba(0, 166, 251, 0.08);
  }

  .button-menu:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .hamburger-line {
    display: block;
    width: 18px;
    height: 2px;
    background-color: var(--color-primary);
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  .button-menu[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .button-menu[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .button-menu[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (width < 810px) {
    .top-bar {
      flex-direction: column;
      align-items: stretch;
      height: auto;
      padding: 0;
    }

    .top-bar-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      padding: 0 16px;
    }

    .button-menu-container {
      display: flex;
    }

    .primary-nav {
      max-height: 0;
      overflow: hidden;
      align-items: stretch;
      transition: max-height 0.3s ease;
    }

    .topbar-wrapper.is-open .primary-nav {
      max-height: 240px;
    }

    .menu-items-container {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      width: 100%;
    }

    .nav-link {
      width: 100%;
      height: 56px;
      padding: 0 16px;
      border-radius: 0;
      justify-content: flex-start;
      font-size: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .topbar-wrapper {
      animation: none;
    }

    .topbar-progress,
    .primary-nav,
    .nav-link,
    .button-menu,
    .hamburger-line {
      transition: none !important;
    }
  }
</style>

<script>
  const topbarWrapper = document.querySelector(".topbar-wrapper");
  const menuButton = document.querySelector(".button-menu");
  const navLinks = Array.from(document.querySelectorAll(".nav-link"));
  const mobileMedia = window.matchMedia("(max-width: 809px)");

  const setProgress = () => {
    if (!topbarWrapper) return;
    const doc = document.documentElement;
    const max = doc.scrollHeight - window.innerHeight;
    const pct =
      max > 0
        ? Math.min(100, Math.max(0, (window.scrollY / max) * 100))
        : 0;
    topbarWrapper.style.setProperty("--progress", pct + "%");
  };

  let scrollTicking = false;
  const onScroll = () => {
    if (scrollTicking) return;
    scrollTicking = true;
    requestAnimationFrame(() => {
      setProgress();
      scrollTicking = false;
    });
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("resize", onScroll, { passive: true });
  setProgress();

  const sections = ["projects", "about", "contact"]
    .map((id) => document.getElementById(id))
    .filter(Boolean);

  const setActive = (id) => {
    navLinks.forEach((link) => {
      const isMatch = link.dataset.section === id;
      link.classList.toggle("is-active", isMatch);
      if (isMatch) {
        link.setAttribute("aria-current", "true");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  };

  if ("IntersectionObserver" in window && sections.length) {
    const visible = new Map();
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            visible.set(entry.target.id, entry.intersectionRatio);
          } else {
            visible.delete(entry.target.id);
          }
        });
        if (visible.size === 0) return;
        let topId = null;
        let topY = Infinity;
        visible.forEach((_, id) => {
          const el = document.getElementById(id);
          if (!el) return;
          const r = el.getBoundingClientRect();
          if (r.top < topY) {
            topY = r.top;
            topId = id;
          }
        });
        if (topId) setActive(topId);
      },
      {
        rootMargin: "-30% 0px -55% 0px",
        threshold: [0, 0.25, 0.5, 0.75, 1],
      },
    );
    sections.forEach((s) => observer.observe(s));
  }

  const openMenu = () => {
    if (!topbarWrapper) return;
    topbarWrapper.classList.add("is-open");
    if (menuButton) {
      menuButton.setAttribute("aria-expanded", "true");
      menuButton.setAttribute("aria-label", "Close menu");
    }
  };

  const closeMenu = () => {
    if (!topbarWrapper) return;
    topbarWrapper.classList.remove("is-open");
    if (menuButton) {
      menuButton.setAttribute("aria-expanded", "false");
      menuButton.setAttribute("aria-label", "Open menu");
    }
  };

  if (menuButton) {
    menuButton.addEventListener("click", () => {
      if (!mobileMedia.matches) return;
      if (topbarWrapper && topbarWrapper.classList.contains("is-open")) {
        closeMenu();
      } else {
        openMenu();
      }
    });
  }

  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (topbarWrapper && topbarWrapper.classList.contains("is-open")) {
        closeMenu();
      }
    });
  });

  document.addEventListener("keydown", (e) => {
    if (
      e.key === "Escape" &&
      topbarWrapper &&
      topbarWrapper.classList.contains("is-open")
    ) {
      e.preventDefault();
      closeMenu();
      if (menuButton) menuButton.focus();
    }
  });
</script>
